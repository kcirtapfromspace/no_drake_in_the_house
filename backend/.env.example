# =============================================================================
# Backend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# Most settings have sensible defaults for development

# =============================================================================
# CORE SETTINGS
# =============================================================================
ENVIRONMENT=development  # development | staging | production

# Server
HOST=0.0.0.0
PORT=3000
REQUEST_TIMEOUT_SECS=30
# Frontend origin used for OAuth callback bounce route
OAUTH_FRONTEND_BASE_URL=http://localhost:5050
# Optional explicit backend callback origin. When omitted, the backend derives it
# from OAUTH_FRONTEND_BASE_URL or the Render external URL.
OAUTH_BACKEND_BASE_URL=http://localhost:3000
# Production example: https://app.nodrakeinthe.house
# Comma-separated list of allowed browser origins for API requests
CORS_ALLOWED_ORIGINS=http://localhost:5050

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgres://ndith:ndith_dev_password@localhost:5432/ndith_dev
DB_MAX_CONNECTIONS=10
DB_CONNECTION_TIMEOUT_SECS=30
DB_IDLE_TIMEOUT_SECS=600

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=10
REDIS_TIMEOUT_SECS=5

# =============================================================================
# AUTHENTICATION
# =============================================================================
# REQUIRED in production - generate with: openssl rand -base64 64
JWT_SECRET=dev_secret_key_do_not_use_in_production_1234567890
# REQUIRED for OAuth provider token storage - generate with: openssl rand -base64 32
OAUTH_ENCRYPTION_KEY=bmRpdGhfZGV2X29hdXRoX2VuY3J5cHRpb25fa2V5X18=

ACCESS_TOKEN_EXPIRY_SECS=3600      # 1 hour
REFRESH_TOKEN_EXPIRY_SECS=604800   # 7 days
BCRYPT_COST=12

# =============================================================================
# MUSIC SERVICE INTEGRATIONS
# =============================================================================

# -----------------------------------------------------------------------------
# APPLE MUSIC (Ready to use)
# -----------------------------------------------------------------------------
# Get credentials from: https://developer.apple.com/account/resources/authkeys/list
# 1. Create a MusicKit identifier
# 2. Create a private key (.p8 file)
# 3. Note your Team ID (top right of developer portal) and Key ID

APPLE_MUSIC_TEAM_ID=          # 10-character Team ID (e.g., XXXXXXXXXX)
APPLE_MUSIC_KEY_ID=           # 10-character Key ID from private key
APPLE_MUSIC_KEY_PATH=         # Path to .p8 private key file
APPLE_MUSIC_BUNDLE_ID=com.nodrakeinthehouse
APPLE_MUSIC_ENFORCE_READINESS=false  # Set true to fail readiness/startup when Apple Music config is missing
# OR use inline key:
# APPLE_MUSIC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# For Sign in with Apple (OAuth)
APPLE_CLIENT_ID=              # Service ID (e.g., com.yourapp.service)
APPLE_TEAM_ID=                # Same as APPLE_MUSIC_TEAM_ID
APPLE_KEY_ID=                 # Same as APPLE_MUSIC_KEY_ID
APPLE_PRIVATE_KEY=            # Same key, inline format
APPLE_REDIRECT_URI=http://localhost:3000/auth/callback/apple

# -----------------------------------------------------------------------------
# YOUTUBE MUSIC (Ready to use)
# -----------------------------------------------------------------------------
# Get credentials from: https://console.cloud.google.com/
# 1. Create a project
# 2. Enable "YouTube Data API v3"
# 3. Create OAuth 2.0 credentials (for user library access)
# 4. Create API Key (for catalog sync)

# OAuth (for user library sync)
YOUTUBE_MUSIC_CLIENT_ID=      # Or use GOOGLE_CLIENT_ID
YOUTUBE_MUSIC_CLIENT_SECRET=  # Or use GOOGLE_CLIENT_SECRET
YOUTUBE_MUSIC_REDIRECT_URI=http://localhost:3000/auth/callback/youtube

# API Key (for catalog operations)
YOUTUBE_API_KEY=              # API key from Google Cloud Console

# -----------------------------------------------------------------------------
# TIDAL (Partial - needs library sync implementation)
# -----------------------------------------------------------------------------
# Get credentials from: https://developer.tidal.com/
# Currently only catalog sync is implemented

TIDAL_CLIENT_ID=
TIDAL_CLIENT_SECRET=
TIDAL_REDIRECT_URI=http://localhost:3000/auth/callback/tidal
# Optional client key for app types that require it
TIDAL_CLIENT_UNIQUE_KEY=
# OAuth mode:
# - modern (default/recommended): OAuth 2.1 + PKCE using login.tidal.com/authorize
# - legacy_force: only for troubleshooting old apps
TIDAL_OAUTH_MODE=modern
# Space or comma separated scopes.
# Modern scopes (recommended): https://developer.tidal.com/documentation/authorization
TIDAL_OAUTH_SCOPES=user.read collection.read playlists.read

# -----------------------------------------------------------------------------
# SPOTIFY
# -----------------------------------------------------------------------------
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:3000/auth/callback/spotify

# -----------------------------------------------------------------------------
# DEEZER (Catalog Only - No OAuth needed)
# -----------------------------------------------------------------------------
# Uses public API - no credentials required
# Rate limit: 50 requests per 5 seconds

# =============================================================================
# GOOGLE OAUTH (for Sign in with Google)
# =============================================================================
# Can share credentials with YouTube Music
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback/google

# =============================================================================
# GITHUB OAUTH (optional - for Sign in with GitHub)
# =============================================================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/auth/callback/github

# =============================================================================
# TOKEN MANAGEMENT
# =============================================================================
TOKEN_REFRESH_INTERVAL_HOURS=1
TOKEN_REFRESH_EXPIRY_THRESHOLD_HOURS=24
TOKEN_REFRESH_BATCH_SIZE=50
TOKEN_REFRESH_RATE_LIMIT_DELAY_MS=100
TOKEN_REFRESH_MAX_RETRIES=3
TOKEN_REFRESH_RETRY_BASE_DELAY_SECS=30

# Token Vault (encryption at rest)
KMS_PROVIDER=mock
# Required for local persistence across backend restarts when using KMS_PROVIDER=mock.
# Accepts 32-byte raw, 64-char hex, or base64-encoded 32-byte key.
KMS_MOCK_MASTER_KEY=ndith_dev_kms_master_key_0000001
DATA_KEY_CACHE_SIZE=10000
TOKEN_VAULT_KEY_ROTATION_DAYS=30
TOKEN_VAULT_HEALTH_CHECK_INTERVAL_HOURS=24
