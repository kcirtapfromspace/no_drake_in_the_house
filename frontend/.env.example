# API Configuration
VITE_API_URL=http://localhost:3000
VITE_API_VERSION=v1
VITE_CONVEX_URL=
VITE_AUTH_MODE=legacy
VITE_EXTENSION_SIGNED_UPDATE_URL=

# Environment Configuration
NODE_ENV=development
VITE_ENVIRONMENT=development

# Feature Flags
VITE_ENABLE_2FA=true
VITE_ENABLE_COMMUNITY_LISTS=true
VITE_ENABLE_ANALYTICS=false

# Development Configuration
VITE_HOT_RELOAD=true
VITE_DEBUG_MODE=true

# External Services (for future use)
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
VITE_APPLE_MUSIC_DEVELOPER_TOKEN=your_apple_music_token_here

# Auth0 / Convex Authentication
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=
VITE_AUTH0_SCOPE="openid profile email offline_access"
VITE_AUTH0_REDIRECT_PATH=/
VITE_AUTH0_CONNECTION_GOOGLE=
VITE_AUTH0_CONNECTION_GITHUB=
VITE_AUTH0_CONNECTION_APPLE=

# UI Configuration
VITE_APP_NAME="No Drake in the House"
VITE_APP_VERSION=0.1.0
VITE_DEFAULT_THEME=light

# Performance Configuration
VITE_ENABLE_SERVICE_WORKER=false
VITE_CACHE_DURATION=300000
